# Copy to .env and fill in values

# Required: Anthropic API key for Genie QA agent
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Databricks connectivity (leave blank to use local Delta tables)
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=dapi...

# Optional: Override default local Delta path
# DELTA_TABLE_PATH=./data/delta

# Optional: Override MLflow tracking URI
# MLFLOW_TRACKING_URI=./data/mlruns
