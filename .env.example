# Copy to .env and fill in values

# ── Databricks (primary mode) ─────────────────────────────────────────────────
DATABRICKS_HOST=https://adb-xxxxxxxxxxxx.azuredatabricks.net
DATABRICKS_TOKEN=dapi...
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/xxxxxxxxxxxx   # SQL warehouse HTTP path

# ── Unity Catalog target ──────────────────────────────────────────────────────
DATABRICKS_CATALOG=dev
DATABRICKS_SCHEMA=safety_stock_gold

# ── MLflow (leave blank to use Databricks managed MLflow on the cluster) ──────
# MLFLOW_TRACKING_URI=databricks   # use 'databricks' when running on a cluster

# ── Databricks Genie space (from notebook 05_setup_genie_space) ──────────────
GENIE_SPACE_ID=01ef1234abcd5678ef90abcdef12

# ── Anthropic API key (optional) ─────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ── Local fallback (when DATABRICKS_HOST is not set) ─────────────────────────
# DELTA_TABLE_PATH=./data/delta
# MLFLOW_TRACKING_URI=./data/mlruns
